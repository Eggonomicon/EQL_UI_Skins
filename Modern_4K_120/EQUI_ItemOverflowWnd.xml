	<Screen item="ItemOverflowWnd">
		<RelativePosition>false</RelativePosition>
		<Location>
			<X>0</X>
			<Y>25</Y>
		</Location>
		<Size>
			<CX>478</CX>
			<CY>480</CY>
		</Size>
		<KeepOnScreen>true</KeepOnScreen>
		<KeepOnScreenOffset>
			<X>-4</X>
			<Y>-4</Y>
		</KeepOnScreenOffset>			

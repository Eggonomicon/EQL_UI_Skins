<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<Listbox item="IOF_ItemList">
		<ScreenID>IOF_ItemList</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorOffset>3</LeftAnchorOffset>
		<TopAnchorOffset>29</TopAnchorOffset>
		<BottomAnchorOffset>87</BottomAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns>
			<Width>29</Width>
			<Heading></Heading>
		</Columns>
		<Columns>
			<Width>132</Width>
			<Heading>Item Name</Heading>
		</Columns>
		<Columns>
			<Width>28</Width>
			<Heading>Qty</Heading>
		</Columns>
		<Columns>
			<Width>72</Width>
			<Heading>Owner</Heading>
		</Columns>
	</Listbox>

	<Button item="IOF_Inspect_Button">
		<ScreenID>IOF_Inspect_Button</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>3</TopAnchorOffset>
		<BottomAnchorOffset>27</BottomAnchorOffset>
		<LeftAnchorOffset>168</LeftAnchorOffset>
		<RightAnchorOffset>87</RightAnchorOffset>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Style_Transparent>false</Style_Transparent>
		<TooltipReference>Click here to inspect the selected item. (R-Click)</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Inspect</Text>
		<Template>BDT_Normal</Template>
	</Button>
	
	<Button item="IOF_Preview_Button">
		<ScreenID>IOF_Preview_Button</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>3</TopAnchorOffset>
		<BottomAnchorOffset>27</BottomAnchorOffset>
		<LeftAnchorOffset>84</LeftAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Style_Transparent>false</Style_Transparent>
		<TooltipReference>Click here to preview the selected item. (Alt R-Click)</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Preview</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="IOF_SelectedItem">
		<ScreenID>IOF_SelectedItem</ScreenID>
		<!--<Font>3</Font>-->
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<LeftAnchorOffset>4</LeftAnchorOffset>
		<TopAnchorOffset>84</TopAnchorOffset>
		<RightAnchorOffset>52</RightAnchorOffset>
		<BottomAnchorOffset>36</BottomAnchorOffset>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>false</Style_Checkbox>
		<Template>BDT_DragItem</Template>
		<DecalOffset>
			<X>0</X>
			<Y>0</Y>
		</DecalOffset>
		<DecalSize>
			<CX>48</CX>
			<CY>48</CY>
		</DecalSize>
	</Button>

	<Label item="IOF_SelectedItemLabel">
		<ScreenID>IOF_SelectedItemLabel</ScreenID>
		<!--<Font>3</Font>-->
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorOffset>56</LeftAnchorOffset>
		<TopAnchorOffset>83</TopAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<BottomAnchorOffset>36</BottomAnchorOffset>
		<Text>Item Being Considered</Text>
		<NoWrap>false</NoWrap>
		<AlignCenter>false</AlignCenter>
		<AlignRight>false</AlignRight>
	</Label>

	<Button item="IOF_Retrieve_Button">
		<ScreenID>IOF_Retrieve_Button</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<LeftAnchorOffset>3</LeftAnchorOffset>
		<TopAnchorOffset>34</TopAnchorOffset>
		<RightAnchorOffset>84</RightAnchorOffset>
		<BottomAnchorOffset>3</BottomAnchorOffset>
		<Style_Transparent>false</Style_Transparent>
		<TooltipReference>Click here to retrieve your item. This cannot be undone.</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Retrieve</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="IOF_Retrieve_All_Button">
		<ScreenID>IOF_Retrieve_All_Button</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<LeftAnchorOffset>87</LeftAnchorOffset>
		<TopAnchorOffset>34</TopAnchorOffset>
		<RightAnchorOffset>180</RightAnchorOffset>
		<BottomAnchorOffset>3</BottomAnchorOffset>
		<Style_Transparent>false</Style_Transparent>
		<TooltipReference>Click here to retrieve all of your items that are accessible to this character including all account wide items.</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Retrieve All</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="IOF_Done_Button">
		<ScreenID>IOF_Done_Button</ScreenID>
		<!--<Font>3</Font>-->
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorOffset>96</LeftAnchorOffset>
		<TopAnchorOffset>34</TopAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<BottomAnchorOffset>3</BottomAnchorOffset>
		<Style_Transparent>false</Style_Transparent>
		<TooltipReference>Click here to close the merchant window</TooltipReference>
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Done</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Label item="IOF_ItemCountLabel">
		<ScreenID>IOF_ItemCountLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>6</X>
			<Y>6</Y>
		</Location>
		<Size>
			<CX>154</CX>
			<CY>17</CY>
		</Size>

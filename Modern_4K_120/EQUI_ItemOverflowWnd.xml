		<TextColor>
			<R>255</R>
			<G>255</G>
			<B>0</B>
		</TextColor>
		<NoWrap>true</NoWrap>
		<AlignCenter>false</AlignCenter>
		<AlignRight>false</AlignRight>
		<AlignLeft>false</AlignLeft>
	</Label>

	<Label item="IOF_ItemCountNumber">
		<ScreenID>IOF_ItemCountNumber</ScreenID>
		<EQType>413</EQType>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>154</X>
			<Y>6</Y>
		</Location>
		<Size>
			<CX>39</CX>
			<CY>17</CY>
		</Size>
		<Text>0</Text>

<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<Button item="ML_ItemIcon">
		<ScreenID>ML_ItemIcon</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>8</X>
			<Y>8</Y>
		</Location>
		<Size>
			<CX>66</CX>
			<CY>66</CY>
		</Size>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<Text />
		<DecalOffset>
			<X>3</X>
			<Y>3</Y>
		</DecalOffset>
		<DecalSize>
			<CX>60</CX>
			<CY>60</CY>
		</DecalSize>
		<ButtonDrawTemplate>
			<Normal>RedIconBackground</Normal>
			<NormalDecal>BuffIcons</NormalDecal>
		</ButtonDrawTemplate>
	</Button>
	
	<Label item="ML_ItemName">
		<ScreenID>ML_ItemName</ScreenID>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>8</TopAnchorOffset>
		<BottomAnchorOffset>80</BottomAnchorOffset>
		<LeftAnchorOffset>75</LeftAnchorOffset>
		<RightAnchorOffset>165</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Text>Item Name</Text>
	</Label>
	
	<Slider item="ML_QtySlider">
		<ScreenID>ML_QtySlider</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>8</TopAnchorOffset>
		<BottomAnchorOffset>38</BottomAnchorOffset>
		<LeftAnchorOffset>158</LeftAnchorOffset>
		<RightAnchorOffset>8</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<SliderArt>SDT_DefSlider</SliderArt>
	</Slider>
	
	<Label item="ML_QtyLbl">
		<ScreenID>ML_QtyLbl</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>48</TopAnchorOffset>
		<BottomAnchorOffset>75</BottomAnchorOffset>
		<LeftAnchorOffset>98</LeftAnchorOffset>
		<RightAnchorOffset>68</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Text>Qty</Text>
	</Label>
	
	<Editbox item="ML_QtySliderInput">
		<ScreenID>ML_QtySliderInput</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>45</TopAnchorOffset>
		<BottomAnchorOffset>75</BottomAnchorOffset>
		<LeftAnchorOffset>60</LeftAnchorOffset>
		<RightAnchorOffset>8</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Style_Border>true</Style_Border>
	</Editbox>

	<Button item="ML_LeaveOnCorpse">
		<ScreenID>ML_LeaveOnCorpse</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>8</X>
			<Y>83</Y>
		</Location>
		<Size>
			<CX>180</CX>
			<CY>38</CY>
		</Size>
		<Text>Leave On Corpse</Text>
		<TooltipReference>Leave this item on the corpse.</TooltipReference>
		<Template>BDT_Normal</Template>
	</Button>

	<Combobox item="ML_GiveSelection">
		<ScreenID>ML_GiveSelection</ScreenID>
		<DrawTemplate>WDT_InnerSolid</DrawTemplate>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>83</TopAnchorOffset>
		<BottomAnchorOffset>120</BottomAnchorOffset>
		<LeftAnchorOffset>195</LeftAnchorOffset>
		<RightAnchorOffset>75</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<ListHeight>150</ListHeight>
		<Button>BDT_Combo</Button>
		<Style_Border>true</Style_Border>
	</Combobox>

	<Button item="ML_GiveButton">
		<ScreenID>ML_GiveButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<TopAnchorOffset>83</TopAnchorOffset>
		<BottomAnchorOffset>120</BottomAnchorOffset>
		<LeftAnchorOffset>68</LeftAnchorOffset>
		<RightAnchorOffset>8</RightAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>true</BottomAnchorToTop>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Text>Give</Text>
		<TooltipReference>Give this item to the selected player.</TooltipReference>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="ML_ActionButton">
		<ScreenID>ML_ActionButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>8</X>
			<Y>128</Y>
		</Location>
		<Size>
			<CX>60</CX>
			<CY>60</CY>
		</Size>
		<Template>BDT_Question</Template>
	</Button>

	<Button item="ML_RollButton">
		<ScreenID>ML_RollButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>195</X>
			<Y>128</Y>
		</Location>
		<Size>
			<CX>60</CX>
			<CY>60</CY>
		</Size>
		<ButtonDrawTemplate>
			<Normal>A_RollNormal</Normal>
			<Pressed>A_RollPressed</Pressed>
			<Flyby>A_RollFlyby</Flyby>
			<PressedFlyby>A_RollPressed</PressedFlyby>
		</ButtonDrawTemplate>
		<TooltipReference>Roll for the item once the Ask action has been completed.</TooltipReference>
	</Button>

	<Button item="ML_FreeGrabButton">
		<ScreenID>ML_FreeGrabButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>195</X>
			<Y>128</Y>
		</Location>
		<Size>
			<CX>60</CX>
			<CY>60</CY>
		</Size>
		<ButtonDrawTemplate>
			<Normal>A_GrabNormal</Normal>
			<Pressed>A_GrabPressed</Pressed>
			<Flyby>A_GrabFlyby</Flyby>
			<PressedFlyby>A_GrabPressed</PressedFlyby>
		</ButtonDrawTemplate>
		<TooltipReference>Free grab - All players can move this item from the shared list to their personal list.</TooltipReference>
	</Button>

	<Button item="ML_AutoRoll">
		<ScreenID>ML_AutoRoll</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>75</X>
			<Y>128</Y>
		</Location>
		<Size>
			<CX>135</CX>
			<CY>24</CY>
		</Size>
		<Style_Checkbox>true</Style_Checkbox>
		<Text>Auto Roll</Text>
		<TooltipReference>Automatically Roll for the item after an Ask action completes.</TooltipReference>
		<Template>BDT_CheckboxWithText</Template>
		<DecalSize>
			<CX>24</CX>
			<CY>24</CY>
		</DecalSize>
		<TextAlignCenter>false</TextAlignCenter>
		<TextOffsetX>30</TextOffsetX>
	</Button>

	<Listbox item="ML_PlayerList">
		<ScreenID>ML_PlayerList</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<Style_VScroll>true</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>15</LeftAnchorOffset>
		<TopAnchorOffset>195</TopAnchorOffset>
		<RightAnchorOffset>15</RightAnchorOffset>
		<BottomAnchorOffset>15</BottomAnchorOffset>
		<TopAnchorToTop>true</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<TextColor>
			<R>0</R>
			<G>148</G>
			<B>255</B>
		</TextColor>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns>
			<Width>240</Width>
			<Heading>Player</Heading>
		</Columns>	
		<Columns>
			<Width>38</Width>
			<Heading>ND</Heading>
		</Columns>	
		<Columns>
			<Width>38</Width>
			<Heading>GD</Heading>
		</Columns>	
		<TooltipReference>List of players responding to an Ask action.</TooltipReference>
	</Listbox>

	<Button item="ML_CheckBoxTemplate">
		<ScreenID>ML_CheckBoxTemplate</ScreenID>
		<RelativePosition>true</RelativePosition>
		<Location>
			<X>0</X>
			<Y>11</Y>
		</Location>
		<Size>
			<CX>24</CX>
			<CY>24</CY>
		</Size>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>true</Style_Checkbox>
		<Text />
		<Template>BDT_Checkbox</Template>
	</Button>

	<Screen item="ManageLootWnd">
		<!--<ScreenID/>-->
		<Location>
			<X>500</X>
			<Y>300</Y>
		</Location>
		<Size>
			<CX>450</CX>
			<CY>450</CY>
		</Size>
		<Text>Manage Loot</Text>
		<DrawTemplate>WDT_Rounded</DrawTemplate>
		<Style_Titlebar>true</Style_Titlebar>
		<Style_Qmarkbox>true</Style_Qmarkbox>
		<Style_Closebox>true</Style_Closebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>true</Style_Sizable>
		<MinHSize>375</MinHSize>
		<MinVSize>327</MinVSize>
		<Pieces>ML_ItemIcon</Pieces>
		<Pieces>ML_QtySlider</Pieces>
		<Pieces>ML_QtyLbl</Pieces>
		<Pieces>ML_QtySliderInput</Pieces>
		<Pieces>ML_ItemName</Pieces>
		<Pieces>ML_LeaveOnCorpse</Pieces>
		<Pieces>ML_GiveSelection</Pieces>
		<Pieces>ML_GiveButton</Pieces>
		<Pieces>ML_ActionButton</Pieces>
		<Pieces>ML_RollButton</Pieces>
		<Pieces>ML_FreeGrabButton</Pieces>
		<Pieces>ML_AutoRoll</Pieces>
		<Pieces>ML_PlayerList</Pieces>
		<Pieces>ML_CheckBoxTemplate</Pieces>
	</Screen>
</XML>
<?xml version="1.0" encoding="us-ascii"?>
<XML ID="EQInterfaceDefinitionLanguage">
  <Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />
  <Label item="LFC_LootFiltersLabel">
    <ScreenID>LFC_LootFiltersLabel</ScreenID>
    <RelativePosition>true</RelativePosition>
    <Location>
      <X>4</X>
      <Y>3</Y>
    </Location>
    <Size>
      <CX>144</CX>
      <CY>17</CY>
    </Size>
    <Text>Source Loot Filters</Text>
    <NoWrap>true</NoWrap>
    <AlignCenter>false</AlignCenter>
    <AlignRight>false</AlignRight>
  </Label>
  <Listbox item="LFC_LootFiltersList">
    <ScreenID>LFC_LootFiltersList</ScreenID>
    <DrawTemplate>WDT_Inner</DrawTemplate>
    <RelativePosition>true</RelativePosition>
	<AutoStretch>true</AutoStretch>
	<TopAnchorToTop>true</TopAnchorToTop>
	<BottomAnchorToTop>false</BottomAnchorToTop>
	<LeftAnchorToLeft>true</LeftAnchorToLeft>
	<RightAnchorToLeft>false</RightAnchorToLeft>
	<TopAnchorOffset>20</TopAnchorOffset>
	<BottomAnchorOffset>29</BottomAnchorOffset>
	<LeftAnchorOffset>3</LeftAnchorOffset>
	<RightAnchorOffset>3</RightAnchorOffset>
    <Style_Border>true</Style_Border>
    <Style_VScroll>true</Style_VScroll>
  </Listbox>
  <Button item="LFC_MergeButton">
    <ScreenID>LFC_MergeButton</ScreenID>
    <RelativePosition>true</RelativePosition>
	<AutoStretch>true</AutoStretch>
	<TopAnchorToTop>false</TopAnchorToTop>
	<BottomAnchorToTop>false</BottomAnchorToTop>
	<LeftAnchorToLeft>true</LeftAnchorToLeft>
	<RightAnchorToLeft>true</RightAnchorToLeft>
	<TopAnchorOffset>27</TopAnchorOffset>
	<BottomAnchorOffset>3</BottomAnchorOffset>
	<LeftAnchorOffset>3</LeftAnchorOffset>
	<RightAnchorOffset>84</RightAnchorOffset>
    <Text>Merge</Text>
    <TooltipReference>Merge any non-existing item loot filter entries into this character's item loot filters from the selected source character.</TooltipReference>
	<Template>BDT_Normal</Template>		
  </Button>
  <Button item="LFC_ReplaceButton">
    <ScreenID>LFC_ReplaceButton</ScreenID>
    <RelativePosition>true</RelativePosition>
	<AutoStretch>true</AutoStretch>
	<TopAnchorToTop>false</TopAnchorToTop>
	<BottomAnchorToTop>false</BottomAnchorToTop>
	<LeftAnchorToLeft>false</LeftAnchorToLeft>
	<RightAnchorToLeft>false</RightAnchorToLeft>
	<TopAnchorOffset>27</TopAnchorOffset>
	<BottomAnchorOffset>3</BottomAnchorOffset>
	<LeftAnchorOffset>84</LeftAnchorOffset>
	<RightAnchorOffset>3</RightAnchorOffset>
    <Text>Replace</Text>
    <TooltipReference>Replace all of this character's item loot filters with all of the selected source character item loot filters.</TooltipReference>
	<Template>BDT_Normal</Template>		
  </Button>
  <!-- Video Modes Screen -->
  <Screen item="LootFiltersCopyWnd">
    <RelativePosition>false</RelativePosition>
    <Location>
      <X>384</X>
      <Y>360</Y>
    </Location>
    <Size>
      <CX>384</CX>
      <CY>276</CY>
    </Size>
	<KeepOnScreen>true</KeepOnScreen>
		<KeepOnScreenOffset>
			<X>-4</X>
			<Y>-4</Y>
		</KeepOnScreenOffset>		
    <Text>Copy Loot Filters</Text>
    <DrawTemplate>WDT_Rounded</DrawTemplate>
    <Style_Titlebar>true</Style_Titlebar>
    <Style_Closebox>true</Style_Closebox>
    <Style_Minimizebox>true</Style_Minimizebox>
    <Style_Qmarkbox>true</Style_Qmarkbox>
    <Style_Border>true</Style_Border>
    <Style_Sizable>false</Style_Sizable>
    <Pieces>LFC_LootFiltersLabel</Pieces>
    <Pieces>LFC_LootFiltersList</Pieces>
    <Pieces>LFC_MergeButton</Pieces>
    <Pieces>LFC_ReplaceButton</Pieces>
  </Screen>
</XML>
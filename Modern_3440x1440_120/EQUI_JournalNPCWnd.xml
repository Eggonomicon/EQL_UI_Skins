			<X>0</X>
			<Y>0</Y>
		</Location>
		<Size>
			<CX>120</CX>
			<CY>96</CY>
		</Size>
		<Style_Border>true</Style_Border>
		<Style_VScroll>true</Style_VScroll>
		<Columns>
			<Width>192</Width>
			<Heading>NPC Name</Heading>
		</Columns>
		<Columns>
			<Width>144</Width>
			<Heading>Zone</Heading>
		</Columns>
		<Columns>
			<Width>192</Width>
			<Heading>Most Recent</Heading>
		</Columns>
	</Listbox>

	<Listbox item="CJNPC_DialogList">
		<ScreenID>DialogList</ScreenID>

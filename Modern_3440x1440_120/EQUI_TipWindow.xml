<?xml version="1.0"?>
<XML ID="EQInterfaceDefinitionLanguage">
	<Schema xmlns="EverQuestData" xmlns:dt="EverQuestDataTypes" />

	<STMLbox item="TIP_Display">
		<ScreenID>Display</ScreenID>
		<DrawTemplate>WDT_Inner</DrawTemplate>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>3</LeftAnchorOffset>
		<TopAnchorOffset>3</TopAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<BottomAnchorOffset>77</BottomAnchorOffset>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<Style_VScroll>true</Style_VScroll>
		<Style_Border>true</Style_Border>
	</STMLbox>

	<Combobox item="TIP_History">
		<ScreenID>History</ScreenID>
		<DrawTemplate>WDT_InnerSolid</DrawTemplate>
		<TooltipReference>Select a previous Tip to view.</TooltipReference>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>3</LeftAnchorOffset>
		<TopAnchorOffset>75</TopAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<BottomAnchorOffset>46</BottomAnchorOffset>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<ListHeight>96</ListHeight>
		<Button>BDT_Combo</Button>
		<Style_Border>true</Style_Border>
	</Combobox>

	<Button item="TIP_NextTipButton">
		<ScreenID>NextTipButton</ScreenID>
		<!--<Font>3</Font>-->
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>168</LeftAnchorOffset>
		<TopAnchorOffset>44</TopAnchorOffset>
		<RightAnchorOffset>87</RightAnchorOffset>
		<BottomAnchorOffset>3</BottomAnchorOffset>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<!--<TooltipReference/>-->
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Show Another Tip</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Button item="TIP_NoShowThisButton">
		<ScreenID>NoShowThisButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>3</LeftAnchorOffset>
		<TopAnchorOffset>44</TopAnchorOffset>
		<RightAnchorOffset>22</RightAnchorOffset>
		<BottomAnchorOffset>24</BottomAnchorOffset>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>true</Style_Checkbox>
		<Text></Text>
		<Template>BDT_Checkbox</Template>
	</Button>

	<Label item="TIP_NoShowThisLabel">
		<ScreenID>NoShowThisLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>24</LeftAnchorOffset>
		<TopAnchorOffset>42</TopAnchorOffset>
		<RightAnchorOffset>120</RightAnchorOffset>
		<BottomAnchorOffset>22</BottomAnchorOffset>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Text>Don't show this tip again</Text>
		<NoWrap>false</NoWrap>
		<AlignCenter>false</AlignCenter>
		<AlignRight>false</AlignRight>
	</Label>

	<Button item="TIP_NoShowButton">
		<ScreenID>NoShowButton</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>3</LeftAnchorOffset>
		<TopAnchorOffset>22</TopAnchorOffset>
		<RightAnchorOffset>22</RightAnchorOffset>
		<BottomAnchorOffset>3</BottomAnchorOffset>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>true</RightAnchorToLeft>
		<Style_Transparent>false</Style_Transparent>
		<Style_Checkbox>true</Style_Checkbox>
		<Text></Text>
		<Template>BDT_Checkbox</Template>
	</Button>

	<Label item="TIP_NoShowLabel">
		<ScreenID>NoShowLabel</ScreenID>
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>24</LeftAnchorOffset>
		<TopAnchorOffset>21</TopAnchorOffset>
		<RightAnchorOffset>120</RightAnchorOffset>
		<BottomAnchorOffset>0</BottomAnchorOffset>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<LeftAnchorToLeft>true</LeftAnchorToLeft>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<Text>Don't show any tips</Text>
		<NoWrap>false</NoWrap>
		<AlignCenter>false</AlignCenter>
		<AlignRight>false</AlignRight>
	</Label>

	<Button item="TIP_CloseButton">
		<ScreenID>CloseButton</ScreenID>
		<!--<Font>3</Font>-->
		<RelativePosition>true</RelativePosition>
		<AutoStretch>true</AutoStretch>
		<LeftAnchorOffset>84</LeftAnchorOffset>
		<TopAnchorOffset>44</TopAnchorOffset>
		<RightAnchorOffset>3</RightAnchorOffset>
		<BottomAnchorOffset>3</BottomAnchorOffset>
		<TopAnchorToTop>false</TopAnchorToTop>
		<BottomAnchorToTop>false</BottomAnchorToTop>
		<RightAnchorToLeft>false</RightAnchorToLeft>
		<LeftAnchorToLeft>false</LeftAnchorToLeft>
		<!--<TooltipReference/>-->
		<Style_Checkbox>false</Style_Checkbox>
		<Text>Close</Text>
		<Template>BDT_Normal</Template>
	</Button>

	<Screen item="TipWindow">
		<!--<ScreenID/>-->
		<RelativePosition>false</RelativePosition>
		<Location>
			<X>336</X>
			<Y>0</Y>
		</Location>
		<Size>
			<CX>432</CX>
			<CY>360</CY>
		</Size>
		<KeepOnScreen>true</KeepOnScreen>
		<KeepOnScreenOffset>
			<X>-4</X>
			<Y>-4</Y>
		</KeepOnScreenOffset>			
		<Text>Tip of the Day</Text>
		<Style_VScroll>false</Style_VScroll>
		<Style_HScroll>false</Style_HScroll>
		<Style_Transparent>false</Style_Transparent>
		<!--<TooltipReference/>-->
		<DrawTemplate>WDT_Rounded</DrawTemplate>
		<Style_Titlebar>true</Style_Titlebar>
		<Style_Closebox>true</Style_Closebox>
		<Style_Minimizebox>true</Style_Minimizebox>
		<Style_Border>true</Style_Border>
		<Style_Sizable>true</Style_Sizable>
		<MinHSize>312</MinHSize>
		<MinVSize>312</MinVSize>		
		<Pieces>TIP_Display</Pieces>
		<Pieces>TIP_CloseButton</Pieces>
		<Pieces>TIP_NoShowThisButton</Pieces>
		<Pieces>TIP_NoShowThisLabel</Pieces>
		<Pieces>TIP_NoShowButton</Pieces>
		<Pieces>TIP_NoShowLabel</Pieces>
		<Pieces>TIP_NextTipButton</Pieces>
		<Pieces>TIP_History</Pieces>
	</Screen>

</XML>
